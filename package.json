{
  "name": "lingma-pallet-tool",
  "version": "1.0.0",
  "description": "货物排版计算工具 - 3D可视化托盘布局计算",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "pack": "electron-builder --dir"
  },
  "author": "Lingma",
  "license": "ISC",
  "build": {
    "appId": "com.lingma.pallettool",
    "productName": "货物排版计算工具",
    "directories": {
      "output": "dist"
    },
    "files": [
      "货物排版计算工具.html",
      "main.js"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "win": {
      "target": "portable"
    },
    "portable": {
      "artifactName": "货物排版计算工具.exe"
    }
  }
}
